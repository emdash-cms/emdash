{
	"name": "@emdash-cms/plugin-worker-mailer",
	"version": "0.1.0",
	"description": "SMTP provider plugin for EmDash CMS on Cloudflare Workers using @workermailer/smtp",
	"type": "module",
	"main": "dist/index.mjs",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.mts"
		}
	},
	"files": [
		"dist"
	],
	"keywords": [
		"emdash",
		"cms",
		"plugin",
		"email",
		"smtp",
		"cloudflare",
		"worker-mailer"
	],
	"author": "Andre Ribas (@RibasSu)",
	"license": "MIT",
	"scripts": {
		"build": "tsdown src/index.ts --format esm --dts --clean",
		"dev": "tsdown src/index.ts --format esm --dts --watch",
		"test": "vitest run",
		"typecheck": "tsgo --noEmit"
	},
	"devDependencies": {
		"tsdown": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"dependencies": {
		"@workermailer/smtp": "^0.1.0",
		"emdash": "workspace:*"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/emdash-cms/emdash.git",
		"directory": "packages/plugins/worker-mailer"
	}
}
