---
/**
 * Portable Text Break/Separator block component
 *
 * Renders horizontal rules and page breaks. Honors block-level `cssClasses`
 * set via the editor's BlockStyleExtension by appending them to the default
 * EmDash classes.
 */
export interface Props {
	node: {
		_type: "break";
		_key: string;
		style?: "line" | "dots" | "space";
		cssClasses?: string;
	};
}

const { node } = Astro.props;
const style = node?.style || "line";
const extra = typeof node?.cssClasses === "string" ? node.cssClasses : undefined;
---

{
	style === "dots" ? (
		<div class:list={["emdash-break emdash-break-dots", extra]}>• • •</div>
	) : style === "space" ? (
		<div class:list={["emdash-break emdash-break-space", extra]} />
	) : (
		<hr class:list={["emdash-break emdash-break-line", extra]} />
	)
}

<style>
	.emdash-break {
		margin: 2rem 0;
	}
	.emdash-break-line {
		border: none;
		border-top: 1px solid #e0e0e0;
	}
	.emdash-break-dots {
		text-align: center;
		color: #999;
		letter-spacing: 0.5em;
	}
	.emdash-break-space {
		height: 2rem;
	}
</style>
