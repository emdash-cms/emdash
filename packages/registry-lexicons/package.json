{
	"name": "@emdash-cms/registry-lexicons",
	"version": "0.0.0",
	"description": "Generated TypeScript types for EmDash plugin registry lexicons (com.emdashcms.experimental.*). EXPERIMENTAL: NSIDs and shapes will change.",
	"type": "module",
	"main": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./lexicons/*": "./lexicons/*.json",
		"./types/*": "./src/generated/types/*.ts"
	},
	"files": [
		"src",
		"lexicons"
	],
	"atcute:lexicons": {
		"mappings": {
			"com.emdashcms.experimental.*": {
				"type": "namespace",
				"path": "./src/generated/types/{{nsid_remainder}}"
			}
		}
	},
	"scripts": {
		"build:types": "lex-cli generate",
		"build:lexicons": "node scripts/copy-lexicons.mjs",
		"build": "pnpm run build:lexicons && pnpm run build:types",
		"typecheck": "tsgo --noEmit",
		"test": "vitest run",
		"check": "publint"
	},
	"dependencies": {
		"@atcute/atproto": "^3.1.11",
		"@atcute/lexicons": "^1.3.0"
	},
	"devDependencies": {
		"@atcute/lex-cli": "^2.8.1",
		"publint": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"keywords": [
		"emdash",
		"cms",
		"plugin-registry",
		"atproto",
		"fair",
		"lexicons"
	],
	"author": "Matt Kane",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/emdash-cms/emdash.git",
		"directory": "packages/registry-lexicons"
	},
	"homepage": "https://github.com/emdash-cms/emdash"
}
