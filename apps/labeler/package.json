		"@emdash-cms/registry-moderation": "workspace:*",
		"ulidx": "^2.4.1"
	},
	"devDependencies": {
		"@atcute/cid": "catalog:",
		"@cloudflare/vite-plugin": "catalog:",
		"@cloudflare/vitest-pool-workers": "catalog:",
