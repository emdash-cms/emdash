				"family": "gpt",
				"attachment": true,
				"reasoning": true,
				"tool_call": true,
				"temperature": false,
				"release_date": "2026-03-12",
				"modalities": {
					"input": ["text", "image", "pdf"],
					"output": ["text"]
				},
				"cost": {
					"input": 1.25,
					"output": 10
				},
				"limit": {
					"context": 400000,
					"output": 128000
				},
				"options": {
