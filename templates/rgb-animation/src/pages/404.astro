---
import Base from "../layouts/Base.astro";
---

<Base title="404 — Page not found">
	<div class="not-found">
		<p class="not-found-code">404</p>
		<h1 class="not-found-title">Page not found</h1>
		<p class="not-found-sub">The page you're looking for doesn't exist.</p>
		<a href="/" class="not-found-back">← Back to home</a>
	</div>
</Base>

<style>
	.not-found {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		padding: var(--spacing-24) var(--spacing-6);
		gap: var(--spacing-4);
	}

	.not-found-code {
		font-family: var(--font-serif);
		font-size: var(--font-size-5xl);
		font-weight: 300;
		color: var(--color-border);
		line-height: 1;
	}

	.not-found-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-3xl);
		font-weight: 300;
	}

	.not-found-sub { color: var(--color-muted); }

	.not-found-back {
		display: inline-block;
		margin-top: var(--spacing-2);
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		text-decoration: none;
		transition: color var(--transition-fast);
	}
	.not-found-back:hover { color: var(--color-text); }
</style>
