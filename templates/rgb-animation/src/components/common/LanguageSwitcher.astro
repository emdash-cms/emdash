---
import { type Locale, getLocaleFromUrl, getAlternatePath, getAlternateLocale, t } from '@/i18n';

const locale = getLocaleFromUrl(Astro.url) as Locale;
const altLocale = getAlternateLocale(locale);
const altPath = getAlternatePath(Astro.url);
---

<div class="lang-switcher">
  <span class:list={['lang-switcher__option', { 'lang-switcher__option--active': locale === 'ja' }]}>
    {locale === 'ja' ? (
      <span>{t(locale, 'common.language.ja')}</span>
    ) : (
      <a href={altPath}>{t(locale, 'common.language.ja')}</a>
    )}
  </span>
  <span class="lang-switcher__divider" aria-hidden="true">/</span>
  <span class:list={['lang-switcher__option', { 'lang-switcher__option--active': locale === 'en' }]}>
    {locale === 'en' ? (
      <span>{t(locale, 'common.language.en')}</span>
    ) : (
      <a href={altPath}>{t(locale, 'common.language.en')}</a>
    )}
  </span>
</div>

<style>
  .lang-switcher {
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-en);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.08em;
  }

  .lang-switcher__divider {
    color: var(--color-text-muted);
  }

  .lang-switcher__option a {
    color: var(--color-text-muted);
    transition: color var(--duration-fast) var(--ease-default);
  }

  .lang-switcher__option a:hover {
    color: var(--color-text-on-dark);
  }

  .lang-switcher__option--active span {
    color: var(--color-accent);
  }
</style>
