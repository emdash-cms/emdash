---
import { type Locale, t, getLocaleFromUrl, getLocalizedPath } from '@/i18n';
import { NAV_CATEGORIES, NAV_SECONDARY } from '@/lib/constants';
import LanguageSwitcher from './LanguageSwitcher.astro';
import SearchBar from './SearchBar.tsx';
import MobileMenu from './MobileMenu.tsx';

const locale = getLocaleFromUrl(Astro.url) as Locale;
const currentPath = Astro.url.pathname;
---

<header class="header" id="header">
  <div class="header__inner">
    <!-- Row 1: Logo + Search -->
    <div class="header__top">
      <a href={getLocalizedPath('/', locale)} class="header__logo" aria-label="RGB Animation Home">
        <span class="header__logo-text">rgb.bg.com</span>
      </a>

      <div class="header__search">
        <SearchBar
          client:load
          locale={locale}
          placeholder={t(locale, 'common.search.placeholder')}
        />
      </div>

      <div class="header__top-links">
        <LanguageSwitcher />
      </div>

      <!-- Mobile hamburger -->
      <MobileMenu
        client:load
        locale={locale}
        categories={NAV_CATEGORIES.map((c) => ({
          label: t(locale, c.key),
          href: getLocalizedPath(c.href, locale),
        }))}
        secondary={NAV_SECONDARY.map((s) => ({
          label: t(locale, s.key),
          href: getLocalizedPath(s.href, locale),
        }))}
        menuLabel={t(locale, 'common.menu')}
        closeLabel={t(locale, 'common.close')}
      />
    </div>

    <!-- Row 2: Navigation -->
    <nav class="header__nav" aria-label="Main navigation">
      <ul class="header__nav-row header__nav-row--primary">
        {NAV_CATEGORIES.map((item) => (
          <li class="header__nav-item">
            <a
              href={getLocalizedPath(item.href, locale)}
              class:list={['header__nav-link header__nav-link--primary', { 'header__nav-link--active': currentPath.includes(item.href) }]}
            >
              {t(locale, item.key)}
            </a>
          </li>
        ))}
      </ul>
      <span class="header__nav-divider" aria-hidden="true">|</span>
      <ul class="header__nav-row header__nav-row--secondary">
        {NAV_SECONDARY.map((item) => (
          <li class="header__nav-item">
            <a
              href={getLocalizedPath(item.href, locale)}
              class:list={['header__nav-link header__nav-link--secondary', { 'header__nav-link--active': currentPath.includes(item.href) }]}
            >
              {t(locale, item.key)}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    background-color: var(--color-bg-dark);
    color: var(--color-text-on-dark);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .header__inner {
    max-width: var(--container-wide);
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  /* Row 1: Logo + Search + Language */
  .header__top {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding-block: var(--space-xs);
  }

  .header__logo {
    display: flex;
    flex-direction: column;
    line-height: 1;
    flex-shrink: 0;
    text-decoration: none;
  }

  .header__logo-text {
    font-family: var(--font-en);
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    color: var(--color-accent);
    letter-spacing: 0.02em;
  }

  .header__search {
    flex: 0 1 300px;
    display: none;
  }

  .header__top-links {
    margin-left: auto;
    display: none;
    align-items: center;
    gap: var(--space-sm);
  }

  /* Row 2: Navigation */
  .header__nav {
    display: none;
    align-items: center;
    gap: var(--space-xs);
    padding-bottom: var(--space-xs);
    overflow-x: auto;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .header__nav::-webkit-scrollbar {
    display: none;
  }

  .header__nav-row {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-shrink: 0;
  }

  .header__nav-divider {
    color: rgba(255, 255, 255, 0.2);
    flex-shrink: 0;
    font-size: var(--text-sm);
  }

  .header__nav-item {
    flex-shrink: 0;
  }

  .header__nav-link {
    font-family: var(--font-en);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: 0.04em;
    padding: 6px 0;
    position: relative;
    transition: color var(--duration-fast) var(--ease-default);
    white-space: nowrap;
  }

  .header__nav-link--primary:hover,
  .header__nav-link--primary.header__nav-link--active {
    color: var(--color-accent);
  }

  .header__nav-link--secondary {
    color: var(--color-text-muted);
  }

  .header__nav-link--secondary:hover {
    color: var(--color-text-on-dark);
  }

  .header__nav-link--active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background-color: var(--color-accent);
  }

  /* Desktop */
  @media (min-width: 1024px) {
    .header__search {
      display: block;
    }

    .header__top-links {
      display: flex;
    }

    .header__nav {
      display: flex;
    }
  }
</style>
