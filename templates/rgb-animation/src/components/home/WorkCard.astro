---
import type { WorkItem } from '@/lib/types';
import type { Locale } from '@/i18n';
import { getLocalizedPath } from '@/i18n';

interface Props {
  work: WorkItem;
  locale: Locale;
  index: number;
}

const { work, locale, index } = Astro.props;
const title = locale === 'en' ? work.titleEn : work.title;
const href = getLocalizedPath(`/works/${work.category}/${work.slug}`, locale);
const delay = (index % 4) + 1;
---

<a href={href} class={`work-card fade-in stagger-${delay}`} title={title}>
  <div class="work-card__image-wrap">
    <img
      src={work.thumbnail}
      alt={title}
      class="work-card__image"
      loading="lazy"
      width="640"
      height="360"
    />
    <span class="work-card__category">{work.category.toUpperCase()}</span>
    <div class="work-card__overlay" aria-hidden="true">
      <span class="work-card__arrow">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
        </svg>
      </span>
    </div>
  </div>
  <div class="work-card__info">
    <h3 class="work-card__title">{title}</h3>
    <span class="work-card__year">{work.year}</span>
  </div>
</a>

<style>
  .work-card {
    display: block;
    border-radius: var(--radius-md);
    overflow: hidden;
    background-color: var(--color-bg-dark);
    transition: transform var(--duration-normal) var(--ease-default),
                box-shadow var(--duration-normal) var(--ease-default);
  }

  .work-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-xl);
  }

  .work-card__image-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background-color: #111;
  }

  .work-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-default);
  }

  .work-card:hover .work-card__image {
    transform: scale(1.06);
  }

  /* Category badge */
  .work-card__category {
    position: absolute;
    top: var(--space-xs);
    left: var(--space-xs);
    padding: 2px 10px;
    font-family: var(--font-en);
    font-size: 0.65rem;
    font-weight: var(--weight-bold);
    letter-spacing: 0.14em;
    background-color: var(--color-accent);
    color: var(--color-text-on-accent);
    border-radius: var(--radius-sm);
  }

  /* Hover overlay arrow */
  .work-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(transparent 60%, rgba(0, 0, 0, 0.6));
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: var(--space-xs);
    opacity: 0;
    transition: opacity var(--duration-normal) var(--ease-default);
  }

  .work-card:hover .work-card__overlay {
    opacity: 1;
  }

  .work-card__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    background-color: var(--color-accent);
    color: #fff;
    transform: translateX(8px);
    transition: transform var(--duration-normal) var(--ease-spring);
  }

  .work-card:hover .work-card__arrow {
    transform: translateX(0);
  }

  /* Info row */
  .work-card__info {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-xs);
    padding: var(--space-xs) var(--space-sm);
    background-color: var(--color-bg-dark);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .work-card__title {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-on-dark);
    line-height: 1.4;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .work-card__year {
    font-family: var(--font-en);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    flex-shrink: 0;
  }
</style>
