---
import type { Locale } from '@/i18n';
import { t, getLocalizedPath } from '@/i18n';
import { getEmDashCollection } from 'emdash';
import WorkCard from './WorkCard.astro';
import type { WorkItem } from '@/lib/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const { entries } = await getEmDashCollection('works');
const works: WorkItem[] = entries.map((entry) => ({
  id: entry.id,
  slug: entry.slug ?? entry.id,
  title: entry.data.title ?? '',
  titleEn: entry.data.title_en ?? '',
  category: entry.data.work_category?.[0] ?? 'film',
  thumbnail: entry.data.featured_image?.src ?? '/images/placeholder-work-1.svg',
  year: Number(entry.data.year) || 2024,
  description: entry.data.description ?? '',
  descriptionEn: entry.data.description_en ?? '',
}));
---

<section class="section section--dark works-grid" id="works">
  <div class="container">
    <div class="section__header fade-in">
      <h2 class="section__title works-grid__title">{t(locale, 'home.works.title')}</h2>
      <div class="section__divider line-draw"></div>
      <p class="section__subtitle">{t(locale, 'home.works.subtitle')}</p>
    </div>

    <div class="works-grid__grid">
      {works.map((work, index) => (
        <WorkCard work={work} locale={locale} index={index} />
      ))}
    </div>

    <div class="works-grid__cta fade-in">
      <a href={getLocalizedPath('/works', locale)} class="works-grid__btn">
        {t(locale, 'common.viewMore')}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .works-grid__title {
    color: var(--color-text-on-dark);
  }

  .works-grid__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-sm);
  }

  @media (min-width: 640px) {
    .works-grid__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .works-grid__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .works-grid__cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-md);
  }

  .works-grid__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: 12px 28px;
    font-family: var(--font-en);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.06em;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    border-radius: var(--radius-sm);
    transition: background-color var(--duration-fast) var(--ease-default),
                color var(--duration-fast) var(--ease-default);
  }

  .works-grid__btn:hover {
    background-color: var(--color-accent);
    color: var(--color-text-on-accent);
  }
</style>
