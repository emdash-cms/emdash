---
import type { ProjectItem } from '@/lib/types';
import type { Locale } from '@/i18n';
import { getLocalizedPath, t } from '@/i18n';

interface Props {
  project: ProjectItem;
  locale: Locale;
  index: number;
}

const { project, locale, index } = Astro.props;
const title = locale === 'en' ? project.titleEn : project.title;
const summary = locale === 'en' ? project.summaryEn : project.summary;
const href = getLocalizedPath(`/projects/${project.slug}`, locale);
const delay = (index % 3) + 1;
---

<a href={href} class={`project-card fade-in stagger-${delay}`}>
  <div class="project-card__thumb-wrap">
    <img
      src={project.thumbnail}
      alt={title}
      class="project-card__thumb"
      loading="lazy"
      width="640"
      height="360"
    />
    {project.status === 'ongoing' && (
      <span class="project-card__badge">Ongoing</span>
    )}
  </div>
  <div class="project-card__body">
    <h3 class="project-card__title">{title}</h3>
    <p class="project-card__summary">{summary}</p>
    <span class="project-card__cta">
      {t(locale, 'common.viewDetails')}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
      </svg>
    </span>
  </div>
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background-color: rgba(255, 255, 255, 0.03);
    transition: transform var(--duration-normal) var(--ease-default),
                border-color var(--duration-normal) var(--ease-default),
                box-shadow var(--duration-normal) var(--ease-default);
  }

  .project-card:hover {
    transform: translateY(-6px);
    border-color: rgba(230, 0, 18, 0.4);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.4);
  }

  .project-card__thumb-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .project-card__thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-default);
  }

  .project-card:hover .project-card__thumb {
    transform: scale(1.05);
  }

  .project-card__badge {
    position: absolute;
    top: var(--space-xs);
    right: var(--space-xs);
    padding: 3px 12px;
    font-family: var(--font-en);
    font-size: 0.65rem;
    font-weight: var(--weight-bold);
    letter-spacing: 0.1em;
    background-color: var(--color-accent);
    color: var(--color-text-on-accent);
    border-radius: var(--radius-full);
    text-transform: uppercase;
  }

  .project-card__body {
    padding: var(--space-sm);
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .project-card__title {
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    color: var(--color-text-on-dark);
    line-height: 1.3;
  }

  .project-card__summary {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
    flex: 1;
  }

  .project-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-en);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.06em;
    color: var(--color-accent);
    margin-top: var(--space-2xs);
    transition: gap var(--duration-fast) var(--ease-default);
  }

  .project-card:hover .project-card__cta {
    gap: 10px;
  }
</style>
