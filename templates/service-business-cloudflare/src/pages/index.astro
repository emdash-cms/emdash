---
import { getEmDashCollection } from "emdash";
import Base from "../layouts/Base.astro";
import ProjectCard from "../components/ProjectCard.astro";

const [servicesResult, projectsResult, reviewsResult, faqsResult, areasResult, settingsResult, certificatesResult] = await Promise.all([
	getEmDashCollection("services", { limit: 6, orderBy: { created_at: "asc" } }),
	getEmDashCollection("projects", { limit: 3, orderBy: { published_at: "desc" } }),
	getEmDashCollection("reviews", { limit: 3 }), getEmDashCollection("faqs", { limit: 5 }),
	getEmDashCollection("service_areas", { limit: 12 }), getEmDashCollection("business_settings", { limit: 1 }),
	getEmDashCollection("certificates", { limit: 6 }),
]);
const business = settingsResult.entries[0]?.data;
if (Astro.cache?.enabled) Astro.cache.set(servicesResult.cacheHint);
---
<Base description={business?.hero_text} schemaType="LocalBusiness">
	<section class="hero"><div class="container hero-grid"><div><p class="eyebrow">Local expertise. Lasting results.</p><h1 {...settingsResult.entries[0]?.edit.hero_heading}>{business?.hero_heading || "Home services done right, the first time."}</h1><p class="hero-copy">{business?.hero_text || "Friendly, skilled professionals for the repairs, improvements, and maintenance your property needs."}</p><div class="hero-actions"><a class="button" href={business?.primary_cta_url || "/contact"}>{business?.primary_cta_label || "Request a free estimate"}</a><a class="button secondary" href="/services">Explore services</a></div><ul><li>Upfront estimates</li><li>Respectful, tidy crews</li><li>Work backed by our guarantee</li></ul></div><div class="hero-panel"><div class="hero-mark" aria-hidden="true">◆</div><strong>Neighbors helping neighbors</strong><p>Serving homes and small businesses across the region since 2011.</p><a href={`tel:${business?.phone}`}>Call {business?.phone}</a></div></div></section>
	<section class="section"><div class="container"><div class="section-heading"><p class="eyebrow">What we do</p><h2>One trusted team for your property</h2><p>Choose a focused service or ask us to coordinate a complete improvement project.</p></div><div class="grid three">{servicesResult.entries.map((service) => <article class="card service-card"><span aria-hidden="true">{service.data.icon || "◆"}</span><h3><a href={`/services/${service.id}`}>{service.data.title}</a></h3><p>{service.data.short_description}</p><a href={`/services/${service.id}`}>Service details →</a></article>)}</div></div></section>
	<section class="section work"><div class="container"><div class="section-heading"><p class="eyebrow">Recent work</p><h2>Care you can see</h2></div><div class="grid three">{projectsResult.entries.map((project) => <ProjectCard title={project.data.title} summary={project.data.summary} location={project.data.location} result={project.data.result} href={`/projects/${project.id}`} image={project.data.gallery?.[0]} />)}</div><p class="center"><a class="button secondary" href="/projects">View project gallery</a></p></div></section>
	<section class="section"><div class="container review-layout"><div><p class="eyebrow">Customer reviews</p><h2>Trusted on the jobs that matter</h2><p>Our reputation is built one careful visit at a time.</p></div><div class="reviews">{reviewsResult.entries.map((review) => <blockquote class="card"><div class="stars" aria-label={`${review.data.rating || 5} out of 5 stars`}>{"★".repeat(review.data.rating || 5)}</div><p>“{review.data.quote}”</p><footer><strong>{review.data.customer_name}</strong>{review.data.location && <span> · {review.data.location}</span>}</footer></blockquote>)}</div></div></section>
	<section class="area-band"><div class="container"><p class="eyebrow">Proudly local</p><h2>Service areas</h2><div class="areas">{areasResult.entries.map((area) => <a href={`/service-areas/${area.id}`}>{area.data.name}</a>)}</div></div></section>
	<section class="section"><div class="container faq-layout"><div><p class="eyebrow">Good to know</p><h2>Frequently asked questions</h2><a href="/contact">Still have a question? Talk with our team.</a></div><div>{faqsResult.entries.map((faq) => <details><summary>{faq.data.question}</summary><p>{faq.data.answer}</p></details>)}</div></div></section>
	<section class="trust"><div class="container"><p>Licensed, trained, and accountable</p><div>{certificatesResult.entries.map((certificate) => <span title={certificate.data.issuer}>{certificate.data.logo_text || certificate.data.name}</span>)}</div></div></section>
	<section class="cta"><div class="container"><div><p class="eyebrow">Let’s get it handled</p><h2>Tell us what your property needs.</h2></div><a class="button" href="/contact">Request a free estimate</a></div></section>
</Base>
<style>
	.hero { padding: clamp(4rem, 9vw, 8rem) 0; background: radial-gradient(circle at 85% 15%, color-mix(in srgb, var(--accent) 32%, transparent), transparent 28%); } .hero-grid { display: grid; grid-template-columns: 1.6fr .8fr; align-items: center; gap: clamp(2rem, 7vw, 7rem); } .hero-copy { font-size: 1.2rem; color: var(--muted); max-width: 44rem; } .hero-actions { display: flex; flex-wrap: wrap; gap: .8rem; margin: 2rem 0; } .hero ul { list-style: none; display: flex; flex-wrap: wrap; gap: 1rem 1.8rem; padding: 0; font-weight: 700; } .hero li::before { content: "✓ "; color: var(--brand); } .hero-panel { padding: 2rem; background: var(--ink); color: var(--bg); border-radius: 1.5rem; box-shadow: var(--shadow); transform: rotate(2deg); } .hero-panel strong { display: block; font-size: 1.45rem; margin-top: 2rem; } .hero-panel a { color: inherit; font-weight: 800; } .hero-mark { color: var(--accent); font-size: 4rem; } .service-card span { font-size: 2rem; color: var(--brand); } .service-card h3 { margin: .8rem 0; } .service-card h3 a { color: var(--ink); text-decoration: none; } .work { background: color-mix(in srgb, var(--brand) 7%, var(--bg)); } .center { text-align: center; margin-top: 2rem; } .review-layout,.faq-layout { display: grid; grid-template-columns: .8fr 1.2fr; gap: clamp(2rem, 7vw, 6rem); } .reviews { display: grid; gap: 1rem; } blockquote { margin: 0; } blockquote footer { background: none; color: var(--muted); padding: 0; } .stars { color: #d78b00; letter-spacing: .1em; } .area-band { background: var(--brand); color: var(--on-brand); padding: 4rem 0; } .area-band .eyebrow { color: inherit; } .areas { display: flex; flex-wrap: wrap; gap: .7rem; } .areas a { color: inherit; border: 1px solid color-mix(in srgb, currentColor 45%, transparent); padding: .5rem .85rem; border-radius: 999px; text-decoration: none; } details { border-bottom: 1px solid var(--border); padding: 1.1rem 0; } summary { font-weight: 750; cursor: pointer; } details p { color: var(--muted); } .trust { padding: 2rem 0; border-block: 1px solid var(--border); } .trust .container,.trust div div { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1.5rem; } .trust span { font-weight: 800; color: var(--muted); } .cta { padding: 4rem 0; background: var(--accent); color: #252116; } .cta .container { display: flex; justify-content: space-between; align-items: center; gap: 2rem; } .cta h2 { margin-bottom: 0; }
	@media (max-width: 800px) { .hero-grid,.review-layout,.faq-layout { grid-template-columns: 1fr; } .hero-panel { transform: none; } .cta .container { display: block; } .cta .button { margin-top: 1rem; } }
</style>
