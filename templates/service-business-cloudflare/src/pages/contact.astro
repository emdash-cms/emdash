---
import { getEmDashCollection } from "emdash";
import Base from "../layouts/Base.astro";
const [settings, areas] = await Promise.all([getEmDashCollection("business_settings", { limit: 1 }), getEmDashCollection("service_areas", { limit: 20 })]);
const business = settings.entries[0]?.data;
if (Astro.cache?.enabled) Astro.cache.set(settings.cacheHint);
---
<Base title="Request an estimate" description="Contact our local service team for a clear, no-pressure estimate." schemaType="LocalBusiness"><section class="section"><div class="container contact"><div><p class="eyebrow">Get in touch</p><h1>Let’s take care of your property.</h1><p>Tell us a little about the job. We’ll follow up within one business day to ask any questions and arrange the next step.</p><div class="card details"><strong>Call</strong><a href={`tel:${business?.phone}`}>{business?.phone}</a><strong>Email</strong><a href={`mailto:${business?.email}`}>{business?.email}</a><strong>Hours</strong><span>{business?.opening_hours}</span></div></div><form class="card" action={`mailto:${business?.email}`} method="post" enctype="text/plain"><label>Name<input required name="name" autocomplete="name" /></label><label>Email<input required type="email" name="email" autocomplete="email" /></label><label>Phone<input type="tel" name="phone" autocomplete="tel" /></label><label>How can we help?<select name="service"><option>General estimate</option><option>Repair or maintenance</option><option>Improvement project</option><option>Commercial service</option></select></label><label>Project details<textarea required name="details" rows="5"></textarea></label><button class="button" type="submit">Send request</button><small>This starter uses your visitor’s email app. Connect the form to your preferred free form service or Worker endpoint before launch.</small></form></div></section><section class="service-strip"><div class="container"><strong>Serving:</strong>{areas.entries.map((area) => <span>{area.data.name}</span>)}</div></section></Base>
<style>.contact{display:grid;grid-template-columns:.8fr 1.2fr;gap:clamp(2rem,7vw,6rem)}.contact>div>p{color:var(--muted);font-size:1.1rem}.details{display:grid;grid-template-columns:auto 1fr;gap:.5rem 1.5rem;margin-top:2rem}.details strong{color:var(--brand)}form{display:grid;gap:1rem}label{display:grid;gap:.35rem;font-weight:700}input,select,textarea{font:inherit;color:var(--ink);background:var(--bg);border:1px solid var(--border);border-radius:.65rem;padding:.75rem}textarea{resize:vertical}form .button{justify-self:start}form small{color:var(--muted)}.service-strip{padding:2rem 0;background:var(--brand);color:white}.service-strip .container{display:flex;flex-wrap:wrap;gap:1rem}.service-strip span{opacity:.85}@media(max-width:800px){.contact{grid-template-columns:1fr}}</style>
