---
interface Props { title: string; summary?: string; location?: string; result?: string; href: string; image?: { src: string; alt: string } }
const { title, summary, location, result, href, image } = Astro.props;
---
<article class="project-card">
	<a href={href} class="project-image" aria-label={`View ${title}`}>
		{image ? <img src={image.src} alt={image.alt} loading="lazy" /> : <span aria-hidden="true">✓</span>}
	</a>
	<div class="project-copy">
		{location && <p class="eyebrow">{location}</p>}
		<h3><a href={href}>{title}</a></h3>
		{summary && <p>{summary}</p>}
		{result && <strong>{result}</strong>}
	</div>
</article>
<style>
	.project-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); }
	.project-image { min-height: 13rem; display: grid; place-items: center; background: linear-gradient(135deg, color-mix(in srgb, var(--brand) 85%, #122), var(--brand)); color: white; text-decoration: none; }
	.project-image span { font-size: 3rem; border: 2px solid currentColor; border-radius: 50%; width: 5rem; height: 5rem; display: grid; place-items: center; }
	.project-image img { width: 100%; height: 100%; min-height: 13rem; object-fit: cover; }
	.project-copy { padding: 1.35rem; }
	.eyebrow { color: var(--brand); font-weight: 700; font-size: .8rem; text-transform: uppercase; letter-spacing: .08em; }
	h3 { margin: .35rem 0 .6rem; font-size: 1.3rem; }
	h3 a { color: var(--ink); text-decoration: none; }
	p { color: var(--muted); }
	strong { display: block; margin-top: .8rem; color: var(--brand); }
</style>
