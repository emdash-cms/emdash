---
import { getEmDashCollection } from "emdash";
import Base from "../layouts/Base.astro";
const [team, certificates] = await Promise.all([getEmDashCollection("team", { limit: 20 }), getEmDashCollection("certificates", { limit: 20 })]);
if (Astro.cache?.enabled) {
	Astro.cache.set(team.cacheHint);
	Astro.cache.set(certificates.cacheHint);
}
---
<Base title="About" description="Meet the local professionals behind our service business."><section class="section"><div class="container intro"><div><p class="eyebrow">About our company</p><h1>Craft, care, and a commitment to our community.</h1></div><p>We built Evergreen Home Services around a simple promise: show up when we say we will, explain the work clearly, and treat every property like our own. Our team combines practical experience with ongoing training so customers can feel confident from the first call to the final walkthrough.</p></div></section><section class="section team"><div class="container"><div class="section-heading"><p class="eyebrow">The people doing the work</p><h2>Meet the team</h2></div><div class="grid three">{team.entries.map((member) => <article class="card"><div class="avatar" aria-hidden="true">{member.data.name.split(" ").map((part) => part[0]).join("")}</div><h3>{member.data.name}</h3><strong>{member.data.role}</strong><p>{member.data.bio}</p>{member.data.years_experience && <small>{member.data.years_experience} years of experience</small>}</article>)}</div></div></section><section class="section"><div class="container"><div class="section-heading"><p class="eyebrow">Standards that matter</p><h2>Certificates and partners</h2></div><div class="credentials">{certificates.entries.map((item) => <article><strong>{item.data.logo_text || item.data.name}</strong><span>{item.data.issuer}</span>{item.data.credential && <small>{item.data.credential}</small>}</article>)}</div></div></section></Base>
<style>.intro { display:grid; grid-template-columns:1.3fr .7fr; gap:4rem; align-items:end; }.intro p:last-child { color:var(--muted); font-size:1.15rem }.team { background:color-mix(in srgb,var(--brand) 7%,var(--bg))}.avatar { width:4rem;height:4rem;display:grid;place-items:center;border-radius:50%;background:var(--brand);color:white;font-weight:800}.card h3{margin:.9rem 0 .2rem}.card strong{color:var(--brand)}.card small{color:var(--muted)}.credentials{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem}.credentials article{border:1px solid var(--border);border-radius:var(--radius);padding:1.4rem;display:grid;gap:.3rem}.credentials span,.credentials small{color:var(--muted)}@media(max-width:800px){.intro,.credentials{grid-template-columns:1fr}}</style>
