			"slug": "services",
			"label": "Services",
			"labelSingular": "Service",
			"supports": ["drafts", "revisions", "search", "seo"],
			"fields": [
				{
					"slug": "title",
					"label": "Title",
					"type": "string",
					"required": true,
					"searchable": true
				},
				{
					"slug": "short_description",
					"label": "Short Description",
					"type": "text",
					"required": true,
					"searchable": true
				},
				{
					"slug": "description",
					"label": "Full Description",
					"type": "portableText",
					"searchable": true
				},
				{ "slug": "icon", "label": "Icon or Symbol", "type": "string" },
				{ "slug": "starting_price", "label": "Pricing Note", "type": "string" },
				{ "slug": "featured", "label": "Featured", "type": "boolean", "defaultValue": false }
			]
		},
		{
			"slug": "projects",
			"label": "Projects & Gallery",
			"labelSingular": "Project",
			"supports": ["drafts", "revisions", "search", "seo"],
			"fields": [
				{
					"slug": "title",
					"label": "Title",
					"type": "string",
					"required": true,
					"searchable": true
				},
				{ "slug": "service", "label": "Service", "type": "string" },
				{ "slug": "location", "label": "Location", "type": "string" },
				{ "slug": "summary", "label": "Summary", "type": "text", "searchable": true },
				{
					"slug": "gallery",
					"label": "Gallery",
					"type": "repeater",
					"validation": {
						"subFields": [
							{ "slug": "src", "type": "string", "label": "Image URL", "required": true },
							{ "slug": "alt", "type": "string", "label": "Alt text", "required": true }
						]
					}
				},
				{ "slug": "result", "label": "Result", "type": "string" }
			]
		},
		{
			"slug": "reviews",
			"label": "Reviews",
			"labelSingular": "Review",
			"supports": ["drafts", "revisions"],
			"fields": [
				{ "slug": "customer_name", "label": "Customer Name", "type": "string", "required": true },
				{ "slug": "quote", "label": "Review", "type": "text", "required": true },
				{
					"slug": "rating",
					"label": "Rating",
					"type": "integer",
					"defaultValue": 5,
					"validation": { "min": 1, "max": 5 }
				},
				{ "slug": "service", "label": "Service", "type": "string" },
				{ "slug": "location", "label": "Location", "type": "string" }
			]
		},
		{
			"slug": "faqs",
			"label": "FAQs",
			"labelSingular": "FAQ",
			"supports": ["drafts", "revisions", "search"],
			"fields": [
				{
					"slug": "question",
					"label": "Question",
					"type": "string",
					"required": true,
					"searchable": true
				},
				{
					"slug": "answer",
					"label": "Answer",
					"type": "text",
					"required": true,
					"searchable": true
