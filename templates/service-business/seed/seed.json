{
	"$schema": "https://emdashcms.com/seed.schema.json",
	"version": "1",
	"meta": {
		"name": "Service Business Starter",
		"description": "A reusable local service-business website",
		"author": "EmDash"
	},
	"settings": {
		"title": "Evergreen Home Services",
		"tagline": "Reliable local care for your home and property"
	},
	"collections": [
		{
			"slug": "business_settings",
			"label": "Business Settings",
			"labelSingular": "Business Settings",
			"description": "Global contact, CTA, and LocalBusiness details",
			"supports": ["revisions"],
			"fields": [
				{ "slug": "business_name", "label": "Business Name", "type": "string", "required": true },
				{ "slug": "phone", "label": "Phone", "type": "string", "required": true },
				{ "slug": "email", "label": "Email", "type": "string", "required": true },
				{ "slug": "street_address", "label": "Street Address", "type": "string" },
				{ "slug": "city", "label": "City", "type": "string" },
				{ "slug": "region", "label": "State or Region", "type": "string" },
				{ "slug": "postal_code", "label": "Postal Code", "type": "string" },
				{ "slug": "opening_hours", "label": "Opening Hours", "type": "string" },
				{ "slug": "price_range", "label": "Schema Price Range", "type": "string" },
				{ "slug": "hero_heading", "label": "Hero Heading", "type": "string" },
				{ "slug": "hero_text", "label": "Hero Text", "type": "text" },
				{ "slug": "primary_cta_label", "label": "Primary CTA Label", "type": "string" },
				{ "slug": "primary_cta_url", "label": "Primary CTA URL", "type": "string" }
