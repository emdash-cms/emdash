				{
					"slug": "name",
					"label": "Area Name",
					"type": "string",
					"required": true,
					"searchable": true
				},
				{ "slug": "region", "label": "State or Region", "type": "string" },
				{ "slug": "description", "label": "Description", "type": "text", "searchable": true }
			]
		},
		{
			"slug": "team",
			"label": "Team",
			"labelSingular": "Team Member",
			"supports": ["drafts", "revisions"],
			"fields": [
				{ "slug": "name", "label": "Name", "type": "string", "required": true },
				{ "slug": "role", "label": "Role", "type": "string", "required": true },
				{ "slug": "bio", "label": "Bio", "type": "text" },
				{ "slug": "years_experience", "label": "Years of Experience", "type": "integer" }
			]
		},
		{
			"slug": "certificates",
			"label": "Certificates & Partners",
			"labelSingular": "Certificate or Partner",
			"supports": ["drafts", "revisions"],
