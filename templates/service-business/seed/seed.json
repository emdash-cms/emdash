				{ "slug": "name", "label": "Name", "type": "string", "required": true },
				{ "slug": "issuer", "label": "Issuer or Partner", "type": "string" },
				{ "slug": "credential", "label": "Credential Details", "type": "string" },
				{ "slug": "logo_text", "label": "Short Logo Text", "type": "string" }
			]
		}
