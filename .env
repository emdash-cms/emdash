# ── EmDash Coolify Deployment — Environment Variables ───────────────────────
# Copy this file to .env and fill in values, OR set these directly in
# Coolify's "Environment Variables" panel for the service.

# ── Required secrets ─────────────────────────────────────────────────────────

# A long random string used to sign auth sessions / tokens.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMDASH_AUTH_SECRET=change-me-to-a-long-random-string

# Optional: secret for signed preview URLs (leave blank to disable preview mode)
EMDASH_PREVIEW_SECRET=

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=4321

# ── Storage paths (defaults work with the Docker volume layout) ──────────────
# DATABASE_URL=file:./data/data.db
# UPLOADS_DIR=./uploads

# ── Optional Cloudflare media (only if you switch away from local storage) ───
# CF_ACCOUNT_ID=
# CF_IMAGES_TOKEN=
# CF_STREAM_TOKEN=
